# Copy this file to `.env.local` and fill in your Supabase project values.
# `.env.local` is gitignored — never commit real keys.
#
# Find these in your Supabase dashboard under Project Settings → API.
# The anon/public key is safe to expose in a client app (Row Level Security
# protects your data), but treat the service_role key as a secret and NEVER
# put it here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Leave both unset to run the app in local-only guest mode (localStorage).
